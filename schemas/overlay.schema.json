{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/100yenadmin/agent-skill-debloater/schemas/overlay.schema.json",
  "title": "AgentSkillDebloater studio overlay",
  "type": "object",
  "required": [
    "studios"
  ],
  "properties": {
    "studios": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "displayName",
          "packs",
          "description"
        ],
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "visibleRouterSkill": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "status": {
            "type": "string",
            "enum": [
              "deferred"
            ]
          },
          "packs": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
            }
          },
          "defaultLimit": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
