{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/100yenadmin/agent-skill-debloater/schemas/pack.schema.json",
  "title": "AgentSkillDebloater pack manifest",
  "type": "object",
  "required": [
    "id",
    "repoUrl",
    "allowedPaths",
    "pinPolicy",
    "licensePolicy",
    "hiddenByDefault",
    "visibility",
    "defaultStudio"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "repoUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "allowedPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?![A-Za-z]:)(?!file:)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.(?:/|$)).+$"
      }
    },
    "pinPolicy": {
      "type": "string",
      "enum": [
        "sha"
      ]
    },
    "licensePolicy": {
      "type": "string",
      "enum": [
        "record-and-review"
      ]
    },
    "hiddenByDefault": {
      "type": "boolean"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "catalog-only"
      ]
    },
    "defaultStudio": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    }
  },
  "additionalProperties": false
}
