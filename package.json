{
  "name": "agent-skill-debloater",
  "version": "1.0.1",
  "description": "Plugin-first searchable catalogs for hidden/read-on-demand agent skill packs.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/100yenadmin/agent-skill-debloater.git"
  },
  "bugs": {
    "url": "https://github.com/100yenadmin/agent-skill-debloater/issues"
  },
  "homepage": "https://github.com/100yenadmin/agent-skill-debloater#readme",
  "keywords": [
    "agent-skills",
    "codex",
    "openclaw",
    "plugin",
    "skill-search",
    "skills"
  ],
  "files": [
    ".codex-plugin/",
    "bin/",
    "catalogs/",
    "docs/",
    "evals/skill-routing-evals/v0/scenarios.json",
    "locks/",
    "overlays/",
    "packs/",
    "schemas/",
    "skills/",
    "src/"
  ],
  "bin": {
    "agent-skill-debloater": "bin/agent-skill-debloater",
    "debloat-skill-search": "bin/debloat-skill-search",
    "pack-sync": "bin/pack-sync"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "eval:routing": "node src/eval-routing.mjs evals/skill-routing-evals/v0/scenarios.json --summary",
    "release:check": "node src/release-report.mjs check",
    "release:notes": "node src/release-report.mjs notes",
    "pack:dry-run": "npm pack --dry-run --json",
    "acceptance:package": "node src/package-acceptance.mjs check",
    "smoke:openclaw-adapter": "node bin/agent-skill-debloater openclaw-adapter search design \"launch hero cover image\""
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
